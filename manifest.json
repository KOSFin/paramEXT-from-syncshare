{
   "action": {
      "browser_style": true,
      "default_icon": {
         "128": "logo_main.png",
         "16": "logo_main.png",
         "24": "logo_main.png",
         "32": "logo_main.png",
         "64": "logo_main.png"
      },
      "default_popup": "html/popup/popup_new.html",
      "default_title": "paramEXT"
   },
   "background": {
      "service_worker": "js/background_worker.js"
   },
   "content_scripts": [ {
      "css": [ "css/widgets/context_menu.css" ],
      "include_globs": [ "*mod/quiz/attempt.php*", "*mod/quiz/review.php*" ],
      "js": [ "js/platform_settings.js", "js/telemetry.js", "js/commons.js", "js/quiz_attempt.js", "js/content_logic.js" ],
      "matches": [ "*://*/*" ],
      "run_at": "document_idle"
   }, {
      "include_globs": [ "*mod/quiz/summary.php*" ],
      "js": [ "js/commons.js", "js/quiz_overview.js" ],
      "matches": [ "*://*/*" ],
      "run_at": "document_idle"
   }, {
      "include_globs": [ "*mod/quiz/view.php*" ],
      "js": [ "js/commons.js", "js/quiz_board.js" ],
      "matches": [ "*://*/*" ],
      "run_at": "document_idle"
   }, {
      "all_frames": true,
      "css": [ "css/widgets/openedu_stick.css" ],
      "include_globs": [ "*://*.openedu.ru/*" ],
      "js": [ "js/platform_settings.js", "js/telemetry.js", "js/openedu_shared.js", "js/openedu_content.js" ],
      "matches": [ "*://*/*" ],
      "run_at": "document_idle"
   } ],
   "content_security_policy": {
      "extension_pages": "default-src 'self'; img-src data:; connect-src 'self' https://syncshare.naloaty.me/api/ https: http:;"
   },
   "default_locale": "en",
   "description": "__MSG_extensionDescription__",
   "homepage_url": "https://syncshare.ru/",
   "host_permissions": [ "*://*/*" ],
   "icons": {
      "128": "logo_main.png",
      "16": "logo_main.png",
      "24": "logo_main.png",
      "32": "logo_main.png",
      "64": "logo_main.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "paramEXT",
   "permissions": [ "storage", "contextMenus" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "2.9.0",
   "web_accessible_resources": [ {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "css/widgets/context_menu.css" ],
      "use_dynamic_url": true
   } ]
}
